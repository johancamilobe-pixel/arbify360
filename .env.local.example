# ─────────────────────────────────────────────────────
# ArbiFy360 — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ─────────────────────────────────────────────────────

# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/arbify360"

# Clerk — Auth
# Obtén estas en: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk — Rutas personalizadas
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/select-academy

# Cloudinary — Almacenamiento de fotos de planillas
# Obtén estas en: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
